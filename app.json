{
  "expo": {
    "name": "trackle",
    "slug": "trackle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "trackle",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.da.trackle",
      "supportsTablet": true
    },
    "android": {
      "package": "com.da.trackle",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@clerk/expo",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Lato-Thin.ttf",
            "./assets/fonts/Lato-Light.ttf",
            "./assets/fonts/Lato-Regular.ttf",
            "./assets/fonts/Lato-Bold.ttf",
            "./assets/fonts/Lato-Black.ttf",
            "./assets/fonts/Lato-Italic.ttf",
            "./assets/fonts/Lato-LightItalic.ttf",
            "./assets/fonts/Lato-BoldItalic.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
